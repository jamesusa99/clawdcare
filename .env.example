# Copy to .env and adjust. Required for sessions in production.
SESSION_SECRET=change-this-to-a-long-random-string

# Public URL of this app (no trailing slash). Used for OAuth redirect.
BASE_URL=http://localhost:3000

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
