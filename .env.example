# Session cookie signing (set a long random string in production)
SESSION_SECRET=change-me-in-production

# Vercel / serverless: required for login to persist (TCP URL from Upstash Redis → "Connect" → copy redis URL)
# REDIS_URL=rediss://default:xxxx@xxxx.upstash.io:6379

# Comma-separated operator emails (bootstrap admin). Strongly recommended for production.
# After `npm run seed:admin`, use this so production recognizes the admin account:
ADMIN_EMAILS=admin@clawdcare.com
# Leave empty on local dev if you want “any logged-in user” admin (see README).
# ADMIN_EMAILS=

# Force strict admin in dev (empty ADMIN_EMAILS will NOT open admin to everyone):
# STRICT_ADMIN=1

# Explicitly allow open admin in dev (redundant if ADMIN_EMAILS is empty):
# ADMIN_DEV_OPEN=1

# Disable the “empty ADMIN_EMAILS = everyone admin” local default:
# ADMIN_DEV_OPEN=0

# Optional: canonical site URL for links in emails or redirects
# BASE_URL=https://clawdcare.com

# Supabase Postgres (optional). When both are set, users are stored in public.profiles instead of data/users.json.
# Create the table with supabase/migrations/20250404140000_clawdcare_profiles.sql
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server only — never expose to the browser
